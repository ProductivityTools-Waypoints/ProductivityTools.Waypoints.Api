type Mutation{
    Hello(name: String!):String
    AddRoute(route: RouteInput!):Route
}

type Query {
    helloQuery: String
    getRoutes:[Route]
    getRoute(id: ID!): Route
}

input RouteInput{
    name: String!
    points: [pointInput]

}
input pointInput{
    name: String!
}

type Route{
    id: ID!,
    name: String,
    points: [Point]
}

type Point {
    name: String
}

